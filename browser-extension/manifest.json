{
  "manifest_version": 3,
  "name": "Min-Conflit Solver",
  "version": "0.1.0",
  "description": "Visualize N-Queens and Sudoku solving locally in Chrome with an offline Min-Conflict workspace.",
  "minimum_chrome_version": "114",
  "permissions": [
    "storage"
  ],
  "action": {
    "default_title": "Min-Conflit Solver",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
